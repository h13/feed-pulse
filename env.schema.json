{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "anyOf": [
    { "required": ["ANTHROPIC_API_KEY"] },
    { "required": ["GLM_API_KEY"] }
  ],
  "properties": {
    "ANTHROPIC_API_KEY": {
      "type": "string",
      "minLength": 1,
      "description": "Anthropic API key for content generation"
    },
    "GLM_API_KEY": {
      "type": "string",
      "minLength": 1,
      "description": "Z.ai GLM API key (Coding Plan)"
    },
    "GLM_API_URL": {
      "type": "string",
      "description": "GLM API endpoint (default: Z.ai Coding Plan)"
    },
    "SLACK_WEBHOOK_URL": {
      "type": "string",
      "description": "Slack incoming webhook URL for notifications"
    },
    "WORDPRESS_API_URL": {
      "type": "string",
      "description": "WordPress REST API base URL"
    },
    "WORDPRESS_USER": {
      "type": "string",
      "description": "WordPress username"
    },
    "WORDPRESS_APP_PASSWORD": {
      "type": "string",
      "description": "WordPress application password"
    },
    "X_API_KEY": {
      "type": "string",
      "description": "X (Twitter) API consumer key"
    },
    "X_API_SECRET": {
      "type": "string",
      "description": "X (Twitter) API consumer secret"
    },
    "X_ACCESS_TOKEN": {
      "type": "string",
      "description": "X (Twitter) access token"
    },
    "X_ACCESS_SECRET": {
      "type": "string",
      "description": "X (Twitter) access token secret"
    }
  }
}
