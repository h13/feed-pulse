{
  "name": "h13/feed-pulse",
  "description": "Automated content pipeline: crawl → match → generate → publish",
  "type": "project",
  "license": "MIT",
  "require": {
    "php": ">=8.4",
    "bear/package": "^1.0",
    "bear/tool-use": "1.x-dev",
    "be-framework/be": "0.x-dev",
    "koriym/env-json": "^1.0",
    "laminas/laminas-feed": "^2.0",
    "symfony/yaml": "^7.0"
  },
  "require-dev": {
    "bear/fake-json": "1.x-dev",
    "phpstan/phpstan": "^2.0",
    "phpunit/phpunit": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "H13\\FeedPulse\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "H13\\FeedPulse\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit",
    "sa": "phpstan analyse -c phpstan.neon",
    "pipeline": "php bin/pipeline.php",
    "publish": "php bin/publish.php",
    "agent": "php bin/agent.php",
    "fake": "php -d BEAR_CONTEXTS=fake-app bin/pipeline.php"
  },
  "repositories": [
    {
      "type": "vcs",
      "url": "https://github.com/bearsunday/BEAR.ToolUse"
    },
    {
      "type": "vcs",
      "url": "https://github.com/bearsunday/BEAR.FakeJson"
    }
  ],
  "minimum-stability": "dev",
  "prefer-stable": true,
  "config": {
    "sort-packages": true
  }
}
