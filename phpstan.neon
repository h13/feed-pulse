parameters:
    level: max
    paths:
        - src
    excludePaths:
        - src/Module/FakeModule.php
    ignoreErrors:
        -
            identifier: class.notFound
            paths:
                - src/Llm/ClaudeClient.php
                - src/Module/AppModule.php
        -
            identifier: property.notFound
            path: src/Module/AppModule.php
        -
            identifier: argument.type
            path: src/Module/AppModule.php
