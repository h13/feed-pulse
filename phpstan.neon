parameters:
    level: max
    paths:
        - src
    excludePaths:
        - src/Module/FakeModule.php
    ignoreErrors:
        - identifier: class.notFound
          path: src/Llm/ClaudeClient.php
        - identifier: argument.type
          path: src/Module/AppModule.php
          message: '#ToolUseModule#'
        - identifier: property.notFound
          path: src/Module/AppModule.php
